---
import b2 from "@src/assets/images/B2.svg";
import { Image } from 'astro:assets';
---

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Next-Gen AI Summit Daily Agenda",
    "description": "Comprehensive 3-day breakdown of technical keynote workshops, developer tracks, and networking panels.",
    "itemListElement": [
      {
        "@type": "Event",
        "position": 1,
        "name": "Day 1: Foundations of Generative AI & LLMs",
        "startDate": "2026-10-15T09:00:00+00:00",
        "endDate": "2026-10-15T19:00:00+00:00",
        "description": "Deep-dives into transformer models, open-source model optimization, and RAG architectures."
      },
      {
        "@type": "Event",
        "position": 2,
        "name": "Day 2: Enterprise AI Infrastructure & MLOps",
        "startDate": "2026-10-16T09:00:00+00:00",
        "endDate": "2026-10-16T20:00:00+00:00",
        "description": "Operationalizing machine learning workflows, vector databases, and secure edge deployments."
      },
      {
        "@type": "Event",
        "position": 3,
        "name": "Day 3: The Autonomous Future & Strategic Networking",
        "startDate": "2026-10-17T09:00:00+00:00",
        "endDate": "2026-10-17T16:00:00+00:00",
        "description": "Panel discussions exploring multi-agent workflows alongside executive strategic partnerships."
      }
    ]
  }
</script>

<section aria-label="Conference Agenda and Schedule" class="bg-accent rounded-card p-10 relative overflow-hidden text-white opacity-0 agenda-surface">
  
  <ul class="flex flex-col gap-16 agenda-list">
    <li class="agenda-item flex flex-col md:flex-row justify-between gap-6 border-b border-zinc-800/60 pb-12">
      <div class="flex-1 flex flex-col text-2xl gap-2 font-bold tracking-tight">
        <span class="text-primary-light text-xl tracking-wider uppercase font-mono">Day 1</span>
        <time datetime="2026-10-15T09:00" class="text-3xl text-white">09:00 - 19:00</time>
      </div>

      <div class="flex-1 flex flex-col gap-4">
        <h3 class="font-bold text-2xl tracking-tight text-white">
          Foundations of Generative AI &amp; Large Language Models
        </h3>
        <p class="text-zinc-400 leading-relaxed text-base">
          Kick off the summit with deep-dives into baseline transformer architectures. Learn cutting-edge optimization techniques for open-source LLMs, custom weight tuning strategies, and enterprise deployment frameworks for Retrieval-Augmented Generation (RAG).
        </p>
      </div>
    </li>

    <li class="agenda-item flex flex-col md:flex-row justify-between gap-6 border-b border-zinc-800/60 pb-12">
      <div class="flex-1 flex flex-col text-2xl gap-2 font-bold tracking-tight">
        <span class="text-primary-light text-xl tracking-wider uppercase font-mono">Day 2</span>
        <time datetime="2026-10-16T09:00" class="text-3xl text-white">09:00 - 20:00</time>
      </div>

      <div class="flex-1 flex flex-col gap-4">
        <h3 class="font-bold text-2xl tracking-tight text-white">
          Enterprise AI Infrastructure &amp; Scalable MLOps
        </h3>
        <p class="text-zinc-400 leading-relaxed text-base">
          Shift the focus to operationalizing artificial intelligence at scale. Industry engineers dissect high-throughput machine learning operations (MLOps), real-time vector database query performance, and secure enterprise data handling layers.
        </p>
      </div>
    </li>

    <li class="agenda-item flex flex-col md:flex-row justify-between gap-6 pb-4">
      <div class="flex-1 flex flex-col text-2xl gap-2 font-bold tracking-tight">
        <span class="text-primary-light text-xl tracking-wider uppercase font-mono">Day 3</span>
        <time datetime="2026-10-17T09:00" class="text-3xl text-white">09:00 - 16:00</time>
      </div>

      <div class="flex-1 flex flex-col gap-4">
        <h3 class="font-bold text-2xl tracking-tight text-white">
          The Autonomous Agent Future &amp; Executive Networking
        </h3>
        <p class="text-zinc-400 leading-relaxed text-base">
          Conclude with tactical panels evaluating multi-agent orchestration frameworks and next-decade technology trends. Wrap up the conference by establishing strategic relationships during the formal B2B executive partnership mixer.
        </p>
      </div>
    </li>
  </ul>

  <Image 
    class="agenda-spinner absolute -bottom-10 -left-20 z-10 pointer-events-none select-none opacity-40 will-change-transform" 
    src={b2} 
    alt="" 
    aria-hidden="true" 
    loading="lazy"
    decoding="async"
  />
</section>

<style>
  /* Native hardware-accelerated spinner loop */
  .agenda-spinner {
    animation: spinInfinite 40s linear infinite;
  }

  @keyframes spinInfinite {
    0% {
      transform: translate3d(0, 0, 0) rotate(0deg);
    }
    100% {
      transform: translate3d(0, 0, 0) rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .agenda-spinner {
      animation-play-state: paused;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReducedMotion) {
    // 1. Reveal the main parent layout surface instantly so it doesn't block the page structure
    gsap.to(".agenda-surface", { opacity: 1, duration: 0.2 });

    // 2. Grab all individual list items
    const agendaItems = document.querySelectorAll(".agenda-item");

    // 3. Loop through each item and give it an isolated ScrollTrigger
    agendaItems.forEach((item) => {
      gsap.from(item, {
        opacity: 0,
        y: 40,
        clipPath: "inset(0% 0% 100% 0%)", // Premium "wipe down" mask effect
        duration: 0.8,
        ease: "power3.out",
        scrollTrigger: {
          trigger: item,            // Each individual <li> triggers itself
          start: "top 85%",          // Triggers when the TOP of the item hits 85% of viewport height
          toggleActions: "play none none none" // Plays once when viewed
        }
      });
    });

    // 4. Animate the background decoration spinner on its own scroll trigger
    gsap.from(".agenda-spinner", {
      opacity: 0,
      scale: 0.7,
      duration: 1.2,
      ease: "power2.out",
      scrollTrigger: {
        trigger: ".agenda-spinner",
        start: "top 90%",
        toggleActions: "play none none none"
      }
    });

  } else {
    // Accessibility Fallback: Just snap everything visible if reduced motion is on
    gsap.to(".agenda-surface", { opacity: 1, duration: 0.1 });
  }
</script>
