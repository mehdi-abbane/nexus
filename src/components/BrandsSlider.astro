---
import dribble_logo from "@src/assets/images/dribble.svg";
import hubspot_logo from "@src/assets/images/hubspot.svg";
import gumroad_logo from "@src/assets/images/gumroad.svg";
import amazon_logo from "@src/assets/images/amazon.svg";
import notion_logo from "@src/assets/images/notion.svg";
import { Image } from 'astro:assets';

// Tip: If this marquee is "above the fold" (visible immediately on load), 
// change loading strategy below to "eager" to maximize LCP speeds.
const imageLoadingStrategy = "eager"; 
---

<section aria-labelledby="sponsors-heading" class="sponsors-list w-full py-8 overflow-hidden bg-black opacity-0 will-change-transform">
  <h2 id="sponsors-heading" class="sr-only">Our Sponsors</h2>

  <div class="marquee-viewport flex w-full gap-12 whitespace-nowrap">
    <ul class="flex min-w-full shrink-0 items-center justify-around gap-12 execution-track" id="logo-track-1">
      <li>
        <Image src={amazon_logo} alt="Amazon Web Services - Enterprise AI Sponsor" loading={imageLoadingStrategy} decoding="async" class="h-8 w-auto object-contain brightness-90 hover:brightness-100 transition-opacity duration-200" />
      </li>
      <li>
        <Image src={dribble_logo} alt="Dribbble - Official Design Track Partner" loading={imageLoadingStrategy} decoding="async" class="h-8 w-auto object-contain brightness-90 hover:brightness-100 transition-opacity duration-200" />
      </li>
      <li>
        <Image src={hubspot_logo} alt="HubSpot - Marketing Automation Partner" loading={imageLoadingStrategy} decoding="async" class="h-8 w-auto object-contain brightness-90 hover:brightness-100 transition-opacity duration-200" />
      </li>
      <li>
        <Image src={gumroad_logo} alt="Gumroad - Creator Economy Sponsor" loading={imageLoadingStrategy} decoding="async" class="h-8 w-auto object-contain brightness-90 hover:brightness-100 transition-opacity duration-200" />
      </li>
      <li>
        <Image src={notion_logo} alt="Notion - Productivity and Workspace Sponsor" loading={imageLoadingStrategy} decoding="async" class="h-8 w-auto object-contain brightness-90 hover:brightness-100 transition-opacity duration-200" />
      </li>
    </ul>

    <ul class="flex min-w-full shrink-0 items-center justify-around gap-12 execution-track" id="logo-track-2" aria-hidden="true">
      <li><Image src={amazon_logo} alt="" loading={imageLoadingStrategy} decoding="async" class="h-8 w-auto object-contain brightness-90" /></li>
      <li><Image src={dribble_logo} alt="" loading={imageLoadingStrategy} decoding="async" class="h-8 w-auto object-contain brightness-90" /></li>
      <li><Image src={hubspot_logo} alt="" loading={imageLoadingStrategy} decoding="async" class="h-8 w-auto object-contain brightness-90" /></li>
      <li><Image src={gumroad_logo} alt="" loading={imageLoadingStrategy} decoding="async" class="h-8 w-auto object-contain brightness-90" /></li>
      <li><Image src={notion_logo} alt="" loading={imageLoadingStrategy} decoding="async" class="h-8 w-auto object-contain brightness-90" /></li>
    </ul>
  </div>
</section>

<style>
  .marquee-viewport {
    mask-image: linear-gradient(to right, transparent, white 15%, white 85%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, white 15%, white 85%, transparent);
  }

  /* Keep CSS loop perfectly simple. Handled entirely on the GPU composite layer */
  .execution-track {
    animation: loopConveyor 35s linear infinite;
  }

  /* Pauses animation when tab is inactive or user prefers reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .execution-track {
      animation-play-state: paused;
    }
  }

  @keyframes loopConveyor {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      /* Matching standard negative flex gap layout perfectly without dynamic calc paints */
      transform: translate3d(-100%, 0, 0);
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  // Use a media query check so JavaScript animations respect reduced motion preferences
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReducedMotion) {
    gsap.fromTo(".sponsors-list", 
      { 
        opacity: 0, 
        // We use y (vertical) instead of x (horizontal). 
        // Shifting a marquee horizontally while it runs horizontally creates immediate layout thrashing.
        y: 30 
      },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ".sponsors-list",
          start: "top 90%",
          toggleActions: "play none none none"
        }
      }
    );
  } else {
    // Fallback if user prefers reduced motion: just snap it visible smoothly
    gsap.to(".sponsors-list", { opacity: 1, duration: 0.3 });
  }
</script>
