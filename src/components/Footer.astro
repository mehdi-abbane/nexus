---
// Footer Component with Transition Persistence Enabled
---

<footer transition:persist class="rounded-card flex flex-col md:flex-row bg-secondary text-accent footer w-full overflow-hidden">
    
    <div class="flex-1 p-10">
        <p class="font-bold mb-10 text-3xl">NextGen AI Summit 2052</p>
        
        <nav aria-label="Footer Site Directory">
            <ul class="grid grid-cols-2 gap-x-10 gap-y-4">
                <li><a href="#agenda" class="hover:text-white transition-colors duration-150">Agenda</a></li>
                <li><a href="#speakers" class="hover:text-white transition-colors duration-150">Speakers</a></li>
                <li><a href="#register" class="hover:text-white transition-colors duration-150">Register</a></li>
                <li><a href="#venue" class="hover:text-white transition-colors duration-150">Venue</a></li>
                <li><a href="#faq" class="hover:text-white transition-colors duration-150">FAQ</a></li>
                <li><a href="#terms" class="hover:text-white transition-colors duration-150">Terms &amp; Conditions</a></li>
                <li><a href="#privacy" class="hover:text-white transition-colors duration-150">Privacy Policy</a></li>
                <li><a href="#cookies" class="hover:text-white transition-colors duration-150">Cookie Policy</a></li>
            </ul>
        </nav>
    </div>
    
    <div class="flex-1 flex flex-col bg-primary rounded-card p-10 text-white gap-6">
        <p class="text-xl font-semibold tracking-wider">STAY UPDATED</p>
        
        <p class="text-white/90">Subscribe for event updates &amp; Exclusive content.</p>
        
        <form class="flex flex-col gap-4" aria-label="Footer Newsletter Signup">
            <div class="w-full">
                <input 
                    type="email" 
                    name="email" 
                    id="footer-subscriber-email"
                    placeholder="Email"
                    aria-label="Business Email Address"
                    required
                    class="block w-full bg-transparent text-white pb-2 border-b border-white focus:outline-none placeholder:text-white/50 transition-colors" 
                />
            </div>
            
            <button type="submit" class="text-accent bg-white hover:bg-transparent border border-transparent rounded-card p-5 hover:text-white font-semibold hover:border-white transition duration-150 w-full sm:w-auto mt-2">
                Stay Updated
            </button>
        </form>
    </div>

</footer>
