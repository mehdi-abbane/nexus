---
import fb from '@src/assets/images/fb.svg'
import ig from '@src/assets/images/ig.svg'
import In from '@src/assets/images/in.svg'
import yt from '@src/assets/images/yt.svg'
import map from '@src/assets/images/map.jpg'
import { Image } from 'astro:assets'
---
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Nexus Summit",
    "url": "https://yourdomain.com",
    "telephone": "+1234556789",
    "email": "mehdi.work.contact@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Horizon Convention Center",
      "addressLocality": "Amsterdam",
      "addressCountry": "NL"
    },
    "sameAs": [
      "https://facebook.com/yourprofile",
      "https://instagram.com/yourprofile",
      "https://linkedin.com/company/yourprofile",
      "https://youtube.com/yourprofile"
    ]
  }
</script>

<section aria-labelledby="contact-heading" class="bg-accent p-5 flex flex-col rounded-card text-white mb-5">
    <div class="flex flex-col lg:flex-row gap-5 justify-between mb-5">

        <div class="flex-1">
            <h2 id="contact-heading" class="text-5xl mb-5 font-bold leading-tight">
                We're here To <br/> Connect And <br/> Assist You
            </h2>
            <p class="mb-7 text-xl text-zinc-300">
                Have questions about the summit? Need help with <br class="hidden sm:inline"/>registration or travel? Our team is ready to assist you.
            </p>
            
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <li>
                    <h3 class="font-semibold text-xl text-zinc-400 tracking-wider">CONTACT US</h3>
                    <p class="mt-1"><a href="tel:+1234556789" class="hover:text-primary transition-colors">+1234556789</a></p>
                </li>
                <li>
                    <h3 class="font-semibold text-xl text-zinc-400 tracking-wider">EVENT LOCATION</h3>
                    <p class="mt-1">Horizon Convention Center <br/> Amsterdam, Netherlands</p>
                </li>
                <li>
                    <h3 class="font-semibold text-xl text-zinc-400 tracking-wider">EMAIL</h3>
                    <p class="mt-1"><a href="mailto:mehdi.work.contact@gmail.com" class="hover:text-primary transition-colors break-all">mehdi.work.contact@gmail.com</a></p>
                </li>
                <li>
                    <h3 class="font-semibold text-xl text-zinc-400 tracking-wider">FOLLOW US</h3>
                    <ul class="flex gap-2 items-center mt-2">
                        <li>
                            <a href="#facebook" aria-label="Follow our event page on Facebook">
                                <Image src={fb} alt="Facebook Profile Link"/>
                            </a>
                        </li>
                        <li>
                            <a href="#instagram" aria-label="Follow our updates on Instagram">
                                <Image src={ig} alt="Instagram Profile Link"/>
                            </a>
                        </li>
                        <li>
                            <a href="#linkedin" aria-label="Connect with our corporate page on LinkedIn">
                                <Image src={In} alt="LinkedIn Enterprise Profile Link"/>
                            </a>
                        </li>
                        <li>
                            <a href="#youtube" aria-label="Watch summit keynotes on YouTube">
                                <Image src={yt} alt="YouTube Stream Channel Link"/>
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>

        <div class="flex-1 flex flex-col gap-5 bg-secondary text-accent rounded-card p-6 sm:p-12 lg:p-20">
            <h3 class="text-xl font-bold tracking-widest uppercase">GET IN TOUCH</h3>
            <p class="">
                Reach out with inquiries about tickets, partnerships or event details.
            </p>
            
            <form class="flex flex-col gap-5">
                <input 
                    type="text" 
                    id="name" 
                    placeholder="Name" 
                    aria-label="Your Full Name"
                    class=" p-3 rounded-md focus:outline-none focus:border-primary transition-colors"
                />
                <input 
                    type="email" 
                    id="email" 
                    placeholder="Email" 
                    aria-label="Your Business Email Address"
                    class=" p-3 rounded-md focus:outline-none focus:border-primary transition-colors"
                />
                <input 
                    type="text" 
                    id="subject" 
                    placeholder="Subject" 
                    aria-label="Inquiry Subject"
                    class=" p-3 rounded-md focus:outline-none focus:border-primary transition-colors"
                />
                <textarea 
                    id="message" 
                    placeholder="Message" 
                    aria-label="Detailed Message Content" 
                    rows="3"
                    class=" p-3 rounded-md focus:outline-none focus:border-primary transition-colors resize-none"
                ></textarea>
                
                <button type="submit" class="bg-primary text-white font-bold p-4 rounded-card hover:opacity-90 transition-opacity uppercase tracking-wider mt-2">
                    Submit Inquiry
                </button>
            </form>
        </div>

    </div>

    <div class="w-full overflow-hidden rounded-card">
        <Image 
            class="w-full object-cover min-h-[250px] sm:min-h-[350px]" 
            src={map} 
            alt="Geographic navigation map pinpointing the Horizon Convention Center site location layout in Amsterdam"
            loading="lazy"
        />
    </div>
</section>
