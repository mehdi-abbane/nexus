---
const testimonials = [
  {
    title: "GAME-CHANGING INSIGHTS",
    quote: "This summit opened my eyes to the potential of AI and how it will shape industries.",
    name: "Mark Vandenberg",
    role: "CTO, NeuralTech",
    avatar: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=120&auto=format&fit=crop&q=80",
    variant: "dark"
  },
  {
    title: "THE BEST AI EVENT!",
    quote: "Incredible speakers, top-tier networking, and cutting-edge discussions all in one place.",
    name: "Elena Rojas",
    role: "AI Researcher, DeepMind",
    avatar: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=120&auto=format&fit=crop&q=80",
    variant: "blue"
  },
  {
    title: "UNMATCHED OPPORTUNITIES",
    quote: "From hands-on workshops to visionary talks, this summit is a must-attend for AI professionals.",
    name: "David Laurent",
    role: "CEO, FutureAI Labs",
    avatar: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&auto=format&fit=crop&q=80",
    variant: "light"
  }
];
---

<section class="bg-black text-white  overflow-hidden select-none antialiased">
  <div class=" mx-auto">
    
    <header class="flex-col md:flex-row flex justify-between items-center my-10">
      <h3 class="text-7xl font-bold">What Past Attendees Say</h3>
      <div class="flex gap-2">
        <button id="prev-btn" class="p-5 border-1 rounded-full slide-button transition-colors duration-200 hover:bg-zinc-900 focus:outline-none active:scale-95 transform">
          <svg width="24" height="16" viewBox="0 0 24 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M8.89611 0.329247C8.44534 -0.109733 7.71449 -0.109733 7.26372 0.329247L0.338103 7.07372C-0.112667 7.5127 -0.112667 8.22442 0.338103 8.6634L7.26372 15.4079C7.71449 15.8469 8.44534 15.8469 8.89611 15.4079C9.34688 14.9689 9.34688 14.2572 8.89611 13.8182L3.94095 8.99264H21.9312C22.5686 8.99264 23.0854 8.48937 23.0854 7.86856C23.0854 7.24775 22.5686 6.74448 21.9312 6.74448L3.94095 6.74448L8.89611 1.91893C9.34688 1.47995 9.34688 0.768227 8.89611 0.329247Z" fill="white"/>
          </svg>
        </button>

        <button id="next-btn" class="rotate-180 p-5 border-1 rounded-full slide-button transition-colors duration-200 hover:bg-zinc-900 focus:outline-none active:scale-95 transform">
          <svg width="24" height="16" viewBox="0 0 24 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M8.89611 0.329247C8.44534 -0.109733 7.71449 -0.109733 7.26372 0.329247L0.338103 7.07372C-0.112667 7.5127 -0.112667 8.22442 0.338103 8.6634L7.26372 15.4079C7.71449 15.8469 8.44534 15.8469 8.89611 15.4079C9.34688 14.9689 9.34688 14.2572 8.89611 13.8182L3.94095 8.99264H21.9312C22.5686 8.99264 23.0854 8.48937 23.0854 7.86856C23.0854 7.24775 22.5686 6.74448 21.9312 6.74448L3.94095 6.74448L8.89611 1.91893C9.34688 1.47995 9.34688 0.768227 8.89611 0.329247Z" fill="white"/>
          </svg>
        </button>
      </div>
    </header>

    <div class="relative w-full h-[400px] flex items-center justify-center">
      <div id="slider-deck" class="relative w-full h-full max-w-5xl">
        
        {testimonials.map((item, index) => (
          <div 
            data-index={index}
            class={`exact-layout-card absolute top-0 left-1/2 w-[88vw] sm:w-[440px] h-[380px] rounded-[32px] p-8 md:p-10 flex flex-col justify-between box-border
              ${item.variant === 'blue' && 'bg-[#0047FF] text-white'}
              ${item.variant === 'dark' && 'bg-[#131316] border border-zinc-900 text-zinc-500'}
              ${item.variant === 'light' && 'bg-[#E5E5E7] text-black'}
            `}
          >
            <div>
              <span class={`block text-xs font-bold tracking-[0.15em] mb-5 uppercase font-mono
                ${item.variant === 'blue' && 'text-blue-200'}
                ${item.variant === 'dark' && 'text-zinc-600'}
                ${item.variant === 'light' && 'text-zinc-500'}
              `}>
                {item.title}
              </span>
              <p class={`text-[16px] md:text-[18px] font-normal leading-relaxed tracking-tight
                ${item.variant === 'blue' && 'text-white'}
                ${item.variant === 'dark' && 'text-zinc-400'}
                ${item.variant === 'light' && 'text-zinc-800'}
              `}>
                "{item.quote}"
              </p>
            </div>

            <div class="flex items-center gap-4">
              <img src={item.avatar} alt={item.name} class="w-11 h-11 rounded-full object-cover" />
              <div>
                <h4 class={`font-bold text-sm tracking-tight ${item.variant === 'light' ? 'text-black' : 'text-white'}`}>
                  {item.name}
                </h4>
                <p class={`text-xs font-medium mt-0.5 ${item.variant === 'blue' ? 'text-blue-200' : 'text-zinc-500'}`}>
                  {item.role}
                </p>
              </div>
            </div>
          </div>
        ))}

      </div>
    </div>

  </div>
</section>

<style>
  /* Premium Motion Curve Engine */
  .exact-layout-card {
    transition: transform 0.75s cubic-bezier(0.16, 1, 0.3, 1), 
                opacity 0.75s cubic-bezier(0.16, 1, 0.3, 1),
                z-index 0.75s ease;
    will-change: transform, opacity;
  }

  /* Desktop Stacking Layout System */
  @media (min-width: 640px) {
    
    /* Top Layer - Center Base (Blue Card) */
    .exact-layout-card.pos-center {
      transform: translateX(-50%) scale(1);
      z-index: 30; 
      opacity: 1;
    }

    /* Top Layer - Appended Right Position (Light Card) */
    .exact-layout-card.pos-right {
      transform: translateX(calc(-50% + 440px + 24px)) scale(1);
      z-index: 25; 
      opacity: 1;
    }

    /* Underlap Layer - Left Position (Dark Card) */
    .exact-layout-card.pos-left {
      transform: translateX(-132%) scale(0.94);
      z-index: 10; 
      opacity: 0.35;
    }
  }

  /* Mobile Presentation Adjustments */
  @media (max-width: 639px) {
    .exact-layout-card.pos-center {
      transform: translateX(-50%) scale(1);
      z-index: 30;
      opacity: 1;
    }
    .exact-layout-card.pos-left {
      transform: translateX(-150%) scale(0.9);
      z-index: 10;
      opacity: 0;
      pointer-events: none;
    }
    .exact-layout-card.pos-right {
      transform: translateX(8%) scale(0.94);
      z-index: 20;
      opacity: 0.4;
    }
  }
</style>

<script>
  function runSymmetricSlider() {
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const cards = Array.from(document.querySelectorAll('.exact-layout-card')) as HTMLElement[];
    
    if (!prevBtn || !nextBtn || cards.length === 0) return;

    let activeIndex = 1; 

    function applyLayoutMatrix() {
      cards.forEach((card, index) => {
        card.classList.remove('pos-center', 'pos-left', 'pos-right');

        if (index === activeIndex) {
          card.classList.add('pos-center');
        } else if (index === (activeIndex - 1 + cards.length) % cards.length) {
          card.classList.add('pos-left');
        } else if (index === (activeIndex + 1) % cards.length) {
          card.classList.add('pos-right');
        }
      });
    }

    nextBtn.addEventListener('click', () => {
      activeIndex = (activeIndex + 1) % cards.length;
      applyLayoutMatrix();
    });

    prevBtn.addEventListener('click', () => {
      activeIndex = (activeIndex - 1 + cards.length) % cards.length;
      applyLayoutMatrix();
    });

    // Touch Interaction
    let startX = 0;
    document.getElementById('slider-deck')?.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
    }, { passive: true });

    document.getElementById('slider-deck')?.addEventListener('touchend', (e) => {
      const endX = e.changedTouches[0].clientX;
      const difference = startX - endX;
      if (difference > 50) nextBtn.click();
      else if (difference < -50) prevBtn.click();
    });

    applyLayoutMatrix();
  }

  document.addEventListener('astro:page-load', runSymmetricSlider);
  runSymmetricSlider();
</script>
<style>

	.slide-button {
		transition: all 150ms;
		&:hover {
			background-color: var(--color-secondary);
			svg {
				path {
				fill: var(--color-primary);
				}
			}
			/* background-color: var(--color-primary); */
		}
	}
</style>
