---
import { Image } from "astro:assets";
import b1 from "@src/assets/images/B1.svg";
---

<section class="bg-accent rounded-card relative flex flex-col gap-10 overflow-hidden p-10 opacity-0 entry-surface">
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "Event",
            "name": "Next-Gen AI Summit",
            "startDate": "2026-10-15T09:00:00+00:00",
            "endDate": "2026-10-17T18:00:00+00:00",
            "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
            "eventStatus": "https://schema.org/EventScheduled",
            "location": {
                "@type": "Place",
                "name": "Horizon Convention Center",
                "address": {
                    "@type": "PostalAddress",
                    "addressLocality": "TechCity",
                    "addressRegion": "Utopolis"
                }
            },
            "description": "Join global tech leaders at the premier Next-Gen AI Summit. Explore cutting-edge breakthroughs in machine learning, generative AI, and deep learning networks.",
            "offers": {
                "@type": "Offer",
                "url": "https://yourdomain.com/#tickets",
                "price": "Check Site",
                "priceCurrency": "USD",
                "availability": "https://schema.org/InStock"
            }
        }
    </script>
    
    <header class="flex justify-between text-lg font-medium">
        <time id="time" datetime="2026-10-15T09:00">OCTOBER 15-17, 2026</time>
        <address id="address" class="text-right not-italic">Horizon Convention Center, TechCity, Utopolis</address>
    </header>

    <div>
        <h2 id="hero-title" class="mb-10 text-7xl font-bold tracking-tight uppercase">
            NEXT-GEN AI <br /> SUMMIT
        </h2>

        <p id="hero-desc" class="mb-10 max-w-2xl text-xl leading-relaxed text-zinc-300">
            Join leading artificial intelligence innovators, data scientists, and machine learning engineers at the premier global tech conference.
            Secure your access to explore next-generation generative AI models, deep learning strategy, and exclusive industry networking.
        </p>

        <a
            href="#tickets"
            class="rounded-card from-primary to-dark inline-block bg-gradient-to-r p-2 text-center font-semibold transition-transform hover:scale-[1.02]"
            title="Register for Next-Gen AI Summit Early Bird Tickets">
            Secure Early Bird Tickets
        </a>
    </div>

    <Image 
        class="hero-spinner absolute top-1 right-0 will-change-transform" 
        src={b1} 
        alt="" 
        aria-hidden="true" 
        loading="eager"
        priority="high"
        decoding="async" 
    />
</section>

<style>
    /* CSS infinite loop offloaded natively to GPU Composite Layer */
    .hero-spinner {
        animation: spinLoop 25s linear infinite;
    }

    @keyframes spinLoop {
        0% {
            transform: translate3d(0, 0, 0) rotate(0deg);
        }
        100% {
            transform: translate3d(0, 0, 0) rotate(360deg);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-spinner {
            animation-play-state: paused;
        }
    }
</style>

<script>
    import gsap from "gsap";

    // Respect user device system motion limitations safely
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!prefersReducedMotion) {
        const tl = gsap.timeline({
            defaults: {
                duration: 0.6,
                ease: "power2.out"
            }
        });

        // Step 1: Smoothly reveal overall container container first to avoid layout shifts
        tl.to(".entry-surface", { opacity: 1, duration: 0.3 })
          
          // Step 2: Animate text layout fields with low pixel bounds to protect core web paint metrics
          .from("#time", { y: -20, opacity: 0 }, "+=0.1")
          .from("#address", { x: 20, opacity: 0 }, "<")
          
          // Clean waterfall execution chain using structural stagger offsets
          .from("#hero-title", { y: 20, opacity: 0 }, "-=0.2")
          .from("#hero-desc", { y: 20, opacity: 0 }, "-=0.3")
          .from(".hero-spinner", { scale: 0.8, opacity: 0 }, "-=0.4");
    } else {
        // Instant visual access fallback layer
        gsap.to(".entry-surface", { opacity: 1, duration: 0.2 });
    }
</script>
