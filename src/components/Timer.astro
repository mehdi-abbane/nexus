---
import Flower from '@src/assets/images/time-flower.svg'
import { Image } from 'astro:assets'
---

<section 
  aria-labelledby="countdown-heading" 
  class="bg-accent rounded-card p-10 relative overflow-hidden flex flex-col items-center justify-center text-center gap-6 w-full text-white"
>
  <h2 id="countdown-heading" class="text-lg font-semibold tracking-[0.2em] uppercase text-zinc-400">
	  Early Bid Pricing Ends In:
  </h2>

  <div 
    class="flex items-center gap-3 sm:gap-6 font-mono select-none" 
    id="summit-countdown"
    data-target-date="2026-10-15T09:00:00"
  >
    <div class="flex flex-col items-center bg-black/30 p-4 rounded-xl min-w-[70px] sm:min-w-[100px]">
      <span id="timer-days" class="text-4xl sm:text-6xl font-bold text-white tabular-nums">00</span>
      <span class="text-[10px] sm:text-xs uppercase tracking-widest text-zinc-500 mt-2 font-sans font-medium">Days</span>
    </div>

    <span class="text-2xl sm:text-4xl font-bold text-zinc-700 animate-pulse">:</span>

    <div class="flex flex-col items-center bg-black/30 p-4 rounded-xl min-w-[70px] sm:min-w-[100px]">
      <span id="timer-hours" class="text-4xl sm:text-6xl font-bold text-white tabular-nums">00</span>
      <span class="text-[10px] sm:text-xs uppercase tracking-widest text-zinc-500 mt-2 font-sans font-medium">Hours</span>
    </div>

    <span class="text-2xl sm:text-4xl font-bold text-zinc-700 animate-pulse">:</span>

    <div class="flex flex-col items-center bg-black/30 p-4 rounded-xl min-w-[70px] sm:min-w-[100px]">
      <span id="timer-minutes" class="text-4xl sm:text-6xl font-bold text-white tabular-nums">00</span>
      <span class="text-[10px] sm:text-xs uppercase tracking-widest text-zinc-500 mt-2 font-sans font-medium">Mins</span>
    </div>

    <span class="text-2xl sm:text-4xl font-bold text-zinc-700 animate-pulse">:</span>

    <div class="flex flex-col items-center bg-black/30 p-4 rounded-xl min-w-[70px] sm:min-w-[100px]">
      <span id="timer-seconds" class="text-4xl sm:text-6xl font-bold text-primary tabular-nums">00</span>
      <span class="text-[10px] sm:text-xs uppercase tracking-widest text-zinc-500 mt-2 font-sans font-medium">Secs</span>
    </div>
  </div>

  <p id="timer-fallback" class="hidden text-xl font-bold text-primary animate-bounce">
    The Summit Has Begun! Secure Last-Minute Access Passes.
  </p>
  <Image src={Flower} alt="Flower Time" class="absolute -bottom-40 right-0"/>
</section>

<script>
  function initializeCountdown() {
    const container = document.getElementById('summit-countdown');
    if (!container) return;

    const targetStr = container.getAttribute('data-target-date');
    const targetDate = new Date(targetStr).getTime();

    const elements = {
      days: document.getElementById('timer-days'),
      hours: document.getElementById('timer-hours'),
      minutes: document.getElementById('timer-minutes'),
      seconds: document.getElementById('timer-seconds'),
      fallback: document.getElementById('timer-fallback')
    };

    function updateTimer() {
      const now = new Date().getTime();
      const distance = targetDate - now;

      if (distance < 0) {
        container.classList.add('hidden');
        if (elements.fallback) elements.fallback.classList.remove('hidden');
        clearInterval(intervalId);
        return;
      }

      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);

      // Pad numbers with leading zeros for layout consistency
      if (elements.days) elements.days.textContent = String(days).padStart(2, '0');
      if (elements.hours) elements.hours.textContent = String(hours).padStart(2, '0');
      if (elements.minutes) elements.minutes.textContent = String(minutes).padStart(2, '0');
      if (elements.seconds) elements.seconds.textContent = String(seconds).padStart(2, '0');
    }

    // Run immediately to avoid a 1-second blank flash state
    updateTimer();
    const intervalId = setInterval(updateTimer, 1000);
  }

  // Runs layout setup perfectly on initial load or Astro page transitions
  initializeCountdown();
  document.addEventListener('astro:after-swap', initializeCountdown);
</script>
