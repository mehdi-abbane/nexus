---
import { Image } from "astro:assets";
import union_1 from "@src/assets/images/union-1.svg";
import arrow_up from "@src/assets/images/arrow-up-right.svg";
---

<script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "ItemList",
        "name": "Next-Gen AI Summit Featured Tracks",
        "description": "Details regarding world-class keynote speakers, emerging artificial intelligence technologies, and executive networking tracks.",
        "itemListElement": [
            {
                "@type": "ListItem",
                "position": 1,
                "name": "Keynote Speakers & AI Pioneers"
            },
            {
                "@type": "ListItem",
                "position": 2,
                "name": "Emerging Technologies, LLMs, and Neural Frameworks"
            },
            {
                "@type": "ListItem",
                "position": 3,
                "name": "B2B AI Networking & Collaborative Workshops"
            }
        ]
    }
</script>

<section id="event-cards" class="flex w-full flex-col gap-5 bg-black text-white md:flex-row opacity-0 event-grid-surface">
    <div class="main-card bg-primary rounded-card flex flex-1 flex-col justify-between p-10">
        <div class="mb-20">
            <h2 class="mb-10 text-3xl font-bold tracking-tight text-white">Speakers</h2>

            <div class="mb-10 flex items-start gap-7">
                <Image src={arrow_up} alt="" aria-hidden="true" loading="lazy" decoding="async" class="mt-1 h-20 w-20 shrink-0" />
                <p class="text-xl leading-snug font-semibold text-zinc-200">
                    Gain unmatched tactical blueprints from the world’s leading artificial intelligence researchers, neural network architects, and
                    ethical tech governance pioneers.
                </p>
            </div>
        </div>

        <div class="mt-auto flex flex-col items-start justify-between gap-6 pt-4 sm:flex-row sm:items-center">
            <div class="flex items-center -space-x-8 overflow-hidden" aria-label="Featured conference speakers preview lineup">
                <Image
                    class="inline-block h-15 w-15 rounded-full bg-zinc-800 object-cover"
                    src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&q=80&w=120"
                    alt="Dr. Aris Thorne, Generative AI Systems Expert"
                    loading="lazy"
                    decoding="async"
                    width="60"
                    height="60"
                />
                <Image
                    class="inline-block h-15 w-15 rounded-full bg-zinc-800 object-cover"
                    src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&q=80&w=120"
                    alt="Marcus Vance, Neural Infrastructure Architect"
                    loading="lazy"
                    decoding="async"
                    width="60"
                    height="60"
                />
                <Image
                    class="inline-block h-15 w-15 rounded-full bg-zinc-800 object-cover"
                    src="https://images.unsplash.com/photo-1580489944761-15a19d654956?auto=format&fit=crop&q=80&w=120"
                    alt="Elena Rostova, Deep Learning Ethics Lead"
                    loading="lazy"
                    decoding="async"
                    width="60"
                    height="60"
                />
                <Image
                    class="inline-block h-15 w-15 rounded-full bg-zinc-800 object-cover"
                    src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&q=80&w=120"
                    alt="Dr. Kenji Sato, NLP Research Director"
                    loading="lazy"
                    decoding="async"
                    width="60"
                    height="60"
                />
            </div>

            <a
                href="#speakers"
                class="rounded-card group flex items-center gap-2 border-1 border-white p-4 text-xl transition-all duration-200 hover:bg-white hover:text-black"
                title="View the complete Next-Gen AI Summit speaker lineup">
                <span>Explore Full Lineup</span>
                <Image src={union_1} alt="" aria-hidden="true" loading="lazy" decoding="async" class="transition-all group-hover:invert" />
            </a>
        </div>
    </div>

    <div class="flex flex-1 flex-col justify-between gap-4">
        <article class="card-1 bg-primary rounded-card flex h-full flex-col justify-center p-5">
            <h3 class="mb-3 text-2xl font-bold tracking-tight text-white">Advanced AI Technologies</h3>
            <p class="text-sm leading-relaxed text-white md:text-base">
                Get hands-on exposure to breakthrough technical developments shaping modern enterprise infrastructure. Master scalable Large Language
                Models (LLMs), predictive computer vision arrays, multimodal transformers, and production-ready automated agent vector pipelines.
            </p>
        </article>

        <article class="card-2 bg-secondary text-accent rounded-card flex h-full flex-col justify-center p-5">
            <h3 class="mb-3 text-2xl font-bold tracking-tight">Networking Opportunities</h3>
            <p class="text-sm leading-relaxed opacity-90 md:text-base">
                Bridge the gap between research and deployment. Engage in dedicated peer-to-peer technical panels, structured founder roundtable
                lunches, and targeted VC matchmaking spaces explicitly curated to build high-value strategic tech partnerships.
            </p>
        </article>
    </div>
</section>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!prefersReducedMotion) {
        // Correct Approach: Create a unified timeline attached to the parent container container
        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: ".event-grid-surface",
                start: "top 85%", // Triggers comfortably before layout elements enter fully into view
                toggleActions: "play none none none" // Fixed structural property typo string
            },
            defaults: {
                duration: 0.6,
                ease: "power2.out"
            }
        });

        // Use clean, low-impact upward translations to avoid cross-axis layout calculations
        tl.to(".event-grid-surface", { opacity: 1, duration: 0.2 })
          .from(".main-card", { y: 30, opacity: 0 })
          .from(".card-1", { y: 20, opacity: 0 }, "-=0.3")
          .from(".card-2", { y: 20, opacity: 0 }, "-=0.4");
    } else {
        // Instantly fallback to plain opacity reveal if accessibility rules are active
        gsap.to(".event-grid-surface", { opacity: 1, duration: 0.3 });
    }
</script>
