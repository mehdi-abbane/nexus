<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!prefersReducedMotion) {
        const highlightCards = document.querySelectorAll(".highlight-card");

        highlightCards.forEach((card) => {
            const number = card.querySelector(".card-number");
            const side = card.getAttribute("data-side");
            
            // Set dynamic initial slide values based on data attribute
            const initialX = side === "left" ? -80 : 80;

            if (number) {
                const tl = gsap.timeline({
                    scrollTrigger: {
                        trigger: card,
                        start: "top 85%",
                        toggleActions: "play none none none"
                    }
                });

                // 1. Smoothly fade/reveal the overall card container
                tl.to(card, { opacity: 1, duration: 0.4 })
                  
                  // 2. Animate the large number from its side drawer position
                  .fromTo(number, 
                    { 
                        opacity: 0, 
                        x: initialX 
                    },
                    { 
                        opacity: 1, 
                        x: 0, 
                        duration: 0.8, 
                        ease: "power2.out" 
                    }, 
                    "-=0.2"
                  );
            }
        });
    } else {
        // Fallback profile for user accessibility compliance 
        gsap.to(".highlight-card, .card-number", { opacity: 1, duration: 0.2 });
    }
</script>
