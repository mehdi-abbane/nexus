    <article class="highlight-card bg-accent rounded-card py-10 p-5 relative overflow-hidden opacity-0 will-change-transform" data-side="left">
        <h3 class="text-lg font-semibold mb-10 uppercase tracking-wider relative z-10">Hands-On Learning</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 relative z-10">
